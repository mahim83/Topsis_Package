# Copy this file to `.streamlit/secrets.toml` for LOCAL runs (it is gitignored),
# OR paste these two lines into the "Secrets" box on Streamlit Community Cloud
# (App → Settings → Secrets) for the DEPLOYED app.
#
# Use a Gmail App Password, NOT your normal account password:
#   https://myaccount.google.com/apppasswords

SENDER_EMAIL = "your_email@gmail.com"
SENDER_PASSWORD = "your_gmail_app_password"
